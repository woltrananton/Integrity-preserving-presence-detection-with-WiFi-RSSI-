# Mall för secrets.yaml — kopiera till secrets.yaml och fyll i dina värden.
# secrets.yaml är gitignored och ska aldrig pushas till repot.

# Lösen för SSH mot Asus-routern (samma som admin-UI:t)
router_password: byt-mig

# Azure IoT Hub connection string för enheten ha-gateway-01
# Hämtas från: Azure Portal → IoT Hub → Devices → ha-gateway-01 → Primary connection string
azure_iot_connection_string: HostName=...;DeviceId=ha-gateway-01;SharedAccessKey=...
